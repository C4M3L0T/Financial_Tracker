[Unit]
Description=ArchTracker - Bot de Telegram para captura de gastos
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
WorkingDirectory=/home/Angel/Escritorio/arch_tracker
ExecStart=/usr/bin/python3 /home/Angel/Escritorio/arch_tracker/bot_listener.py
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
